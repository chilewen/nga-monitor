name: NGA User Monitor

on:
  schedule:
    # 每 10 分钟运行一次 (UTC 时间，请注意时差，这里写的是每10分)
    - cron: '*/10 * * * *'
  workflow_dispatch: # 允许手动点击运行测试

jobs:
  check-post:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      - name: Install dependencies
        run: |
          pip install requests

      - name: Run Monitor Script
        run: python monitor.py

      # 关键步骤：保存 last_post_id.txt 到 GitHub Cache 或 Artifact
      # 因为 GitHub Actions 每次运行都是全新的环境，必须持久化存储上次的 TID
      - name: Save Last TID
        uses: actions/cache/save@v3
        with:
          path: last_post_id.txt
          key: nga-last-tid-${{ github.run_id }}
          restore-keys: |
            nga-last-tid-
      
      # 实际上上面的 cache/save 比较复杂，更简单的做法是利用 GitHub Secrets 存储状态
      # 但为了简化，我们可以用一个 Trick：利用 GitHub Issues 或 简单的文件提交来记录
      # 【修正方案】：最简单的方法是让脚本把新状态 commit 回仓库，或者使用 GitHub Environment Variables
      # 下面采用 "Commit back to repo" 的方式记录状态 (最稳妥)
      
      - name: Commit and push if changed
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add last_post_id.txt
          git diff --quiet && git diff --staged --quiet || git commit -m "Update last post ID"
          git push
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
